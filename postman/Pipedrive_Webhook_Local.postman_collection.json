{
  "info": {
    "_postman_id": "f3e89f8b-d7cb-4f65-9f90-4f6fa3f6d8b4",
    "name": "Pipedrive API CRUD + Webhook Trigger",
    "description": "Запросы в API Pipedrive (не в локальный webhook). Подходит для создания/изменения/удаления сущностей и проверки, что после этого прилетает webhook на ваш сервер.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Deals - List (GET /v1/deals)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{pipedriveBaseUrl}}/v1/deals?api_token={{apiToken}}&limit=50&start=0",
          "host": [
            "{{pipedriveBaseUrl}}"
          ],
          "path": [
            "v1",
            "deals"
          ],
          "query": [
            {
              "key": "api_token",
              "value": "{{apiToken}}"
            },
            {
              "key": "limit",
              "value": "50"
            },
            {
              "key": "start",
              "value": "0"
            }
          ]
        }
      }
    },
    {
      "name": "Deals - Get By ID (GET /v1/deals/{id})",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{pipedriveBaseUrl}}/v1/deals/{{dealId}}?api_token={{apiToken}}",
          "host": [
            "{{pipedriveBaseUrl}}"
          ],
          "path": [
            "v1",
            "deals",
            "{{dealId}}"
          ],
          "query": [
            {
              "key": "api_token",
              "value": "{{apiToken}}"
            }
          ]
        },
        "description": "Перед запуском подставьте dealId."
      }
    },
