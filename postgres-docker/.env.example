# Скопируйте в `.env` в этой же папке (не путать с `.env` приложения в корне репозитория).
# Docker Compose подхватывает `.env` здесь для подстановки в docker-compose.yml.

POSTGRES_USER=pipedrive
POSTGRES_PASSWORD=замените_на_свой_пароль
POSTGRES_DB=pipedrive
# Порт на хосте (маппинг host:5436 → контейнер:5432)
POSTGRES_PORT=5436
