# Pipedrive: токен в Settings → Personal preferences → API
# Не коммитьте реальные значения.
PIPEDRIVE_API_TOKEN=

# Поддомен компании из URL аккаунта: https://ВАШ_ПОДДОМЕН.pipedrive.com
# Если задан — запросы идут на https://ВАШ_ПОДДОМЕН.pipedrive.com/api/v1/...
# Тогда PIPEDRIVE_API_BASE_URL ниже не используется.
PIPEDRIVE_COMPANY_DOMAIN=yourcompany

# Только если домен компании НЕ задаёте: центральный API
# PIPEDRIVE_API_BASE_URL=https://api.pipedrive.com

# PostgreSQL — строка подключения для sync (psycopg3)
#
# Локально: postgres-docker/README.md — чаще 127.0.0.1 и порт из POSTGRES_PORT.
# Удалённый сервер (пример): подставьте пароль; спецсимволы в пароле — URL-encode.
# DATABASE_URL=postgresql://pipedrive:YOUR_PASSWORD@217.25.88.237:5436/pipedrive
DATABASE_URL=postgresql://pipedrive:pipedrive@127.0.0.1:5432/pipedrive

# Регистрация webhook в Pipedrive (scripts/register_pipedrive_webhooks.py):
# один webhook на все объекты и действия (*.*, v2). URL приёмника POST /webhook (как снаружи).
# Достаточно домена — скрипт добавит /webhook: WEBHOOK_PUBLIC_URL=https://pulse.omnic.solutions
# или явно: WEBHOOK_PUBLIC_URL=https://pulse.omnic.solutions/webhook
# Второй webhook на другой URL без удаления первого: задайте --url и опционально --name в командной строке (см. docstring register_pipedrive_webhooks.py).
#
# Опционально: если задан — клиент (часто reverse proxy) должен слать Authorization: Bearer <WEBHOOK_SECRET>.
# WEBHOOK_SECRET=
#
# Логи webhook-сервиса: LOG_LEVEL=INFO (по умолчанию), для сырого JSON тела — WEBHOOK_LOG_BODY=1
#
# Проверка домена Pipedrive (webhook v2): meta.host в теле должен совпадать с PIPEDRIVE_COMPANY_DOMAIN
# (поддомен → yourcompany.pipedrive.com). Переопределение: WEBHOOK_EXPECTED_HOST=subdomain.pipedrive.com
# Отключить проверку (только отладка): WEBHOOK_DISABLE_META_HOST_CHECK=1
#
# Опционально ограничение по IP — см. раньше; обычно достаточно meta.host.
# WEBHOOK_ALLOWED_IPS=

# --- PeopleForce (API v3, см. https://developer.peopleforce.io/docs/authentication) ---
# Ключ: Settings -> Open API keys -> Generate. Заголовок X-API-KEY.
PEOPLEFORCE_API_KEY=
PEOPLEFORCE_API_BASE_URL=https://app.peopleforce.io/api/public/v3
#
# Схема и выгрузка: python -m src.peopleforce.sync --init-db
# python -m src.peopleforce.sync
# Webhook в том же контейнере, что Pipedrive: POST https://ВАШ_ДОМЕН/peopleforce/webhook
# В UI PeopleForce: Settings -> Webhooks -> Secret -> PEOPLEFORCE_WEBHOOK_SECRET (подпись x-peopleforce-signature)
PEOPLEFORCE_WEBHOOK_SECRET=
# Локальная/боев: python scripts/test_peopleforce_webhook_http.py
# Тот же хост, что WEBHOOK_PUBLIC_URL (Pipedrive), путь /peopleforce/webhook — подставится из WEBHOOK_PUBLIC_URL, если нет:
# PEOPLEFORCE_WEBHOOK_TEST_URL=https://hooks.ваш-домен.ru/peopleforce/webhook
PEOPLEFORCE_LOG_BODY=1

# --- Google Analytics 4 (проба: python scripts/google_analytics_probe.py) ---
# GA_PROPERTY=350179697
# OAuth Desktop JSON в корне: google_oauth_client.json (см. .gitignore). Опционально:
# GA_REFRESH_TOKEN=
# pip install -r requirements-google-analytics.txt
#
# Синк в Postgres («вебхук» = cron): python -m src.google_analytics.sync --init-db
# затем python -m src.google_analytics.sync --days 7
# Docker: сервис cron в docker-compose.yml — все задания из docker/cron.d/*.cron.
# Расписание правьте в этих файлах (или смонтируйте каталог docker/cron.d). Для GA смонтируйте
# google_oauth_client.json (см. docker-compose.yml).
# GA_SYNC_DAYS=2
# daily_user: в Data API нет userPseudoId/userId. Создайте в GA4 Custom definition (User scope),
# затем укажите имя параметра:
# GA_SYNC_USER_CUSTOM_DIMENSION=my_user_key
# или полное измерение:
# GA_SYNC_USER_DIMENSION=customUser:my_user_key
# Явно выключить пользовательский отчёт: GA_SYNC_USER_DIMENSION=none
# GA_SYNC_PAGE_LIMIT=5000

# Опционально: учётка для compose — в postgres-docker/.env (см. postgres-docker/.env.example)
# POSTGRES_USER=pipedrive
# POSTGRES_PASSWORD=pipedrive
# POSTGRES_DB=pipedrive
# POSTGRES_PORT=5436
