# Pipedrive: токен в Settings → Personal preferences → API
# Не коммитьте реальные значения.
PIPEDRIVE_API_TOKEN=

# Поддомен компании из URL аккаунта: https://ВАШ_ПОДДОМЕН.pipedrive.com
# Если задан — запросы идут на https://ВАШ_ПОДДОМЕН.pipedrive.com/api/v1/...
# Тогда PIPEDRIVE_API_BASE_URL ниже не используется.
PIPEDRIVE_COMPANY_DOMAIN=yourcompany

# Только если домен компании НЕ задаёте: центральный API
# PIPEDRIVE_API_BASE_URL=https://api.pipedrive.com

# PostgreSQL — строка подключения для sync (psycopg3)
#
# Локально: postgres-docker/README.md — чаще 127.0.0.1 и порт из POSTGRES_PORT.
# Удалённый сервер (пример): подставьте пароль; спецсимволы в пароле — URL-encode.
# DATABASE_URL=postgresql://pipedrive:YOUR_PASSWORD@217.25.88.237:5436/pipedrive
DATABASE_URL=postgresql://pipedrive:pipedrive@127.0.0.1:5432/pipedrive

# Регистрация webhook в Pipedrive (scripts/register_pipedrive_webhooks.py):
# полный публичный HTTPS URL эндпоинта, с путём /webhook — как открывается снаружи.
# WEBHOOK_PUBLIC_URL=https://hooks.ваш-домен.ru/webhook
#
# Опционально: если задан — клиент (часто reverse proxy) должен слать Authorization: Bearer <WEBHOOK_SECRET>.
# WEBHOOK_SECRET=

# Опционально: учётка для compose — в postgres-docker/.env (см. postgres-docker/.env.example)
# POSTGRES_USER=pipedrive
# POSTGRES_PASSWORD=pipedrive
# POSTGRES_DB=pipedrive
# POSTGRES_PORT=5436
